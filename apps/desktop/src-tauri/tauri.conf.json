{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "loci",
  "version": "0.1.0",
  "identifier": "com.inteye.loci",
  "mainBinaryName": "loci-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "loci",
        "width": 1200,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "category": "DeveloperTool",
    "shortDescription": "Local-first codebase understanding desktop app",
    "longDescription": "loci desktop packages indexing, graph navigation, trace inspection, documentation generation, and evaluation into a single local application.",
    "publisher": "inteye",
    "copyright": "Copyright (c) inteye",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
